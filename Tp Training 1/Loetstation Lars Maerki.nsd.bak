<?xml version="1.0" encoding="UTF-8"?>
<root xmlns:nsd="https://structorizer.fisch.lu" version="3.32-35" preRepeat="until " postFor="to" preReturn="return" postForIn="in" preWhile="while " output="OUTPUT" input="INPUT" preFor="for" preExit="exit" preLeave="leave" ignoreCase="true" preThrow="throw" preForIn="foreach" stepFor="by" namespace="" author="Lars" created="2026-05-21" changedby="Lars" changed="2026-05-21" origin="Structorizer 3.32-35" text="&#34;Loetstation Lars 21.05.2026&#34;" comment="" color="ffffff" type="program" style="nice">
	<children>
		<instruction text="&#34;Hardware Initialisieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;Alle Variablen Initialisieren und auf 0 setzten&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;zustand_Loetstation definieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;zustand_Loetstation = Aus&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;array einlesenTemparaturSensor definieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
		<instruction text="&#34;array ausgabeTemparaturAnzeige definieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
		<while text="&#34;Unendlichschlaufe&#34;" comment="&#34;&#34;" color="ffffff" disabled="0">
			<qWhile>
				<instruction text="&#34;Eingabe&#34;" comment="" color="c0c0c0" rotated="0" disabled="1"></instruction>
				<instruction text="&#34;Flankenerkennung&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;den Wert von inTaster in inTaster_alt speichern&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;Taster einlesen und in inTaster speichern&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;Positive Flanken mit Bitlogik bestimmen&#34;,&#34;inPosTaster = inTaster_alt nicht gesetzt UND inTaster gesetzt&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;Schalter einlesen und in inSchalter speichern&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;inSchalterAnAus aus inSchalter Maskieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;inTempSensor aus inSchalter Maskieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;inTasterUp aus inPosTaster Maskieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;inTasterDown aus inPosTaster Maskieren&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;istTempereatur = einlesenTemperaturSensor[inTempsensor]&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;Systemzeit in inZeit_ms abspeichern&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;Verarbeitung&#34;" comment="" color="c0c0c0" rotated="0" disabled="1"></instruction>
				<alternative text="&#34;Betriebsschalter = 0&#34;" comment="" color="ffffff" branch_colors="ff8080," disabled="0">
					<qTrue>
						<instruction text="&#34;Zustand_Loetstation = Aus&#34;" comment="" color="ff80c0" rotated="0" disabled="0"></instruction>
					</qTrue>
					<qFalse>
						<alternative text="&#34;Tempsensor = 0&#34;" comment="" color="ffffff" branch_colors="ff8080," disabled="0">
							<qTrue>
								<instruction text="&#34;zustand_Loetstation = Fehler&#34;" comment="" color="ff8080" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="ffffff">
							</qFalse>
						</alternative>
					</qFalse>
				</alternative>
				<case text="&#34;Normalbetrieb&#34;,&#34;Aus&#34;,&#34;Fehler&#34;,&#34;Standby&#34;,&#34;Temp_Diff&#34;,&#34;default&#34;" comment="" color="ffffff" branch_colors="ff80c0,ff8080,80ff80,80ffff," disabled="0">
					<qCase>
						<instruction text="&#34;Betriebsanzeige = 0&#34;" comment="" color="ff80c0" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;Heizanzeige = 0&#34;" comment="" color="ff80c0" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;Temperaturanzeige = 0&#34;" comment="" color="ff80c0" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinkenTempDif = 0&#34;" comment="&#34;&#34;" color="ff80c0" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinken_Fehler = 0&#34;" comment="&#34;&#34;" color="ff80c0" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagFunktionTaster = 0&#34;" comment="&#34;&#34;" color="ff80c0" rotated="0" disabled="0"></instruction>
						<alternative text="&#34;Betriebsschalter = 1&#34;" comment="" color="ff80c0" branch_colors="80ff80," disabled="0">
							<qTrue>
								<instruction text="&#34;zustand_Loetstation = Standby&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="ff80c0">
							</qFalse>
						</alternative>
					</qCase>
					<qCase>
						<instruction text="&#34;Betriebsanzeige = 1&#34;" comment="" color="ff8080" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;Heizanzeige = 0&#34;" comment="" color="ff8080" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinkenTempDif = 0&#34;" comment="" color="ff8080" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinken_Fehler = 1&#34;" comment="" color="ff8080" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagFunktionTaster = 0&#34;" comment="" color="ff8080" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;solltemperatur = Fehlerzustand&#34;" comment="" color="ff8080" rotated="0" disabled="0"></instruction>
						<alternative text="&#34;Tempsensor nicht 0&#34;" comment="" color="ff8080" branch_colors="80ff80," disabled="0">
							<qTrue>
								<instruction text="&#34;zustand_Loetstation = Standby&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="ff8080">
							</qFalse>
						</alternative>
					</qCase>
					<qCase>
						<instruction text="&#34;Betriebsanzeige = 1&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;Heizanzeige = 0&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;Temperaturanzeige = 0&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagFunktionTaster = 1&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinkenTempDif = 0&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinken_Fehler = 0&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
						<alternative text="&#34;sollTemparatur nicht gleich istTemparatur&#34;" comment="" color="80ff80" branch_colors="80ffff," disabled="0">
							<qTrue>
								<instruction text="&#34;zustand_Loetstation = Temp_Diff&#34;" comment="" color="80ffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="80ff80">
							</qFalse>
						</alternative>
					</qCase>
					<qCase>
						<instruction text="&#34;Betriebsanzeige = 1&#34;" comment="" color="80ffff" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinkenTempDif = 1&#34;" comment="" color="80ffff" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagBlinken_Fehler = 0&#34;" comment="" color="80ffff" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;flagFunktionTaster = 1&#34;" comment="" color="80ffff" rotated="0" disabled="0"></instruction>
						<alternative text="&#34;sollTemparatur = istTemparatur&#34;" comment="" color="80ffff" branch_colors="80ff80," disabled="0">
							<qTrue>
								<instruction text="&#34;zustand_Loetstation = Standby&#34;" comment="" color="80ff80" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="80ffff">
							</qFalse>
						</alternative>
						<alternative text="&#34;sollTemparatur &#62; istTemparatur&#34;" comment="" color="80ffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;Heizanzeige = 1&#34;" comment="" color="80ffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse>
								<instruction text="&#34;Heizanzeige = 0&#34;" comment="" color="80ffff" rotated="0" disabled="0"></instruction>
							</qFalse>
						</alternative>
					</qCase>
					<qCase color="ffffff">
					</qCase>
				</case>
				<alternative text="&#34;flagFunktionTaster&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
					<qTrue>
						<alternative text="&#34;inTasterUp = 1 und sollTemparatur nicht gleich Maximalwert&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;sollTemparatur = sollTemparatur + 10K&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="ffffff">
							</qFalse>
						</alternative>
						<alternative text="&#34;intasterDown = 1 und sollTemparatur nicht gleich Minimalwert&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;sollTemparatur = sollTemparatur - 10K&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="ffffff">
							</qFalse>
						</alternative>
					</qTrue>
					<qFalse>
						<instruction text="&#34;sollTemperatur = 350C&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qFalse>
				</alternative>
				<instruction text="&#34;Ausgabe&#34;" comment="" color="c0c0c0" rotated="0" disabled="1"></instruction>
				<alternative text="&#34;flagBlinkenTempDif = 1&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
					<qTrue>
						<alternative text="&#34;BlinkTimerTempDiff 500ms vergangen&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;BlinkTimerTempDiff = sytemZeit_ms&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="ffffff">
							</qFalse>
						</alternative>
						<alternative text="&#34;BlinkTimerTempDiff 20ms vergangen&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;blinken = 0&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse>
								<instruction text="&#34;blinken = 1&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qFalse>
						</alternative>
					</qTrue>
					<qFalse>
						<instruction text="&#34;BlinkTimerTempDiff = sytemZeit_ms&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
						<instruction text="&#34;blinken = 1&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qFalse>
				</alternative>
				<alternative text="&#34;FlagBlinken_Fehler = 1&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
					<qTrue>
						<alternative text="&#34;BlinkTimerTempDiff 1s vergangen&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;BlinkTimerTempDiff = sytemZeit_ms&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse color="ffffff">
							</qFalse>
						</alternative>
						<alternative text="&#34;BlinkTimerTempDiff 500ms vergangen&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;blinken = 0&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse>
								<instruction text="&#34;blinken = 1&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qFalse>
						</alternative>
					</qTrue>
					<qFalse>
						<instruction text="&#34;BlinkTimerTempDiff = sytemZeit_ms&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qFalse>
				</alternative>
				<instruction text="&#34;outTempAnzeige = ausgabeTemparaturAnzeige[sollTemperatur]&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;outTempAnzeige = outTempAnzeige * blinken&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;Ausgabevariablen Maskieren und in outLedspeichern&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
				<instruction text="&#34;outLed an den Led's ausgeben&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
			</qWhile>
		</while>
	</children>
</root>